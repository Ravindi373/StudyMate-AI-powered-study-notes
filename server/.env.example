# Port the Express server listens on
PORT=5000

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/studymate
# Atlas:  mongodb+srv://<user>:<url-encoded-password>@<cluster>.mongodb.net/studymate
MONGODB_URI=mongodb://127.0.0.1:27017/studymate

# Anthropic API key used for the /summarize endpoint (Part 4)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
